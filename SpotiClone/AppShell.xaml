<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:SpotiClone.Views"
       x:Class="SpotiClone.AppShell">

    <TabBar>
        <ShellContent Route="home"
                      Title="{OnPlatform iOS='Головна', MacCatalyst=''}"
                      ContentTemplate="{DataTemplate views:HomePage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MaterialIcons"
                                 Glyph="&#xe88a;"
                                 Color="{StaticResource TextSecondary}"
                                 Size="24"/>
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent Route="search"
                      Title="{OnPlatform iOS='Пошук', MacCatalyst=''}"
                      ContentTemplate="{DataTemplate views:SearchPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MaterialIcons"
                                 Glyph="&#xe8b6;"
                                 Color="{StaticResource TextSecondary}"
                                 Size="24"/>
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent Route="library"
                      Title="{OnPlatform iOS='Бібліотека', MacCatalyst=''}"
                      ContentTemplate="{DataTemplate views:LibraryPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MaterialIcons"
                                 Glyph="&#xe030;"
                                 Color="{StaticResource TextSecondary}"
                                 Size="24"/>
            </ShellContent.Icon>
        </ShellContent>

        <ShellContent Route="history"
                      Title="{OnPlatform iOS='Історія', MacCatalyst=''}"
                      ContentTemplate="{DataTemplate views:HistoryPage}">
            <ShellContent.Icon>
                <FontImageSource FontFamily="MaterialIcons"
                                 Glyph="&#xe889;"
                                 Color="{StaticResource TextSecondary}"
                                 Size="24"/>
            </ShellContent.Icon>
        </ShellContent>
    </TabBar>

</Shell>
