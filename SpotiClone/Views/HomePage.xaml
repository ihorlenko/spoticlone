<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SpotiClone.Views.Controls"
             xmlns:helpers="clr-namespace:SpotiClone.Helpers"
             x:Class="SpotiClone.Views.HomePage"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource PageBackground}">

    <ContentPage.Resources>
        <helpers:DurationConverter x:Key="DurationConverter"/>
    </ContentPage.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content area -->
        <Grid Grid.Row="0">
            <!-- Loading indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource SpotifyGreen}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

            <!-- Main content -->
            <ScrollView IsVisible="{Binding IsNotBusy}">
                <VerticalStackLayout Spacing="24" Padding="16,16,0,40"
                                     MaximumWidthRequest="1200"
                                     HorizontalOptions="Center">

                    <Label Text="Ласкаво просимо"
                           Style="{StaticResource TitleLabel}"
                           Margin="0,0,16,0"/>

                    <!-- ── Нові треки ── -->
                    <HorizontalStackLayout Spacing="8" Margin="0,8,16,0" VerticalOptions="Center">
                        <BoxView WidthRequest="4" HeightRequest="22"
                                 Color="{StaticResource SpotifyGreen}"
                                 BackgroundColor="Transparent"
                                 VerticalOptions="Center"
                                 CornerRadius="2"/>
                        <Label Text="Нові треки"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="21"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <CollectionView x:Name="TracksView"
                                    ItemsSource="{Binding RecentTracks}"
                                    HeightRequest="200">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <Label Text="Немає треків"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}"
                                        Padding="0"
                                        WidthRequest="160">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference TracksView}, Path=BindingContext.PlayTrackCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid HeightRequest="190">

                                        <!-- Cover fills full card -->
                                        <Image Source="{Binding Track.CoverUrl}"
                                               Aspect="AspectFill"/>

                                        <!-- Genre badge — top left -->
                                        <Border StrokeThickness="0"
                                                Stroke="Transparent"
                                                StrokeShape="RoundRectangle 10"
                                                BackgroundColor="#CC121212"
                                                HorizontalOptions="Start"
                                                VerticalOptions="Start"
                                                Margin="6,6,0,0"
                                                Padding="6,3">
                                            <Label Text="{Binding Track.Genre}"
                                                   FontSize="10"
                                                   TextColor="{StaticResource TextSecondary}"/>
                                        </Border>

                                        <!-- Like button — top right -->
                                        <Button Text="&#xe87e;"
                                                FontFamily="MaterialIcons"
                                                FontSize="18"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource TextSecondary}"
                                                Command="{Binding Source={x:Reference TracksView}, Path=BindingContext.ToggleLikeCommand}"
                                                CommandParameter="{Binding .}"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                WidthRequest="36" HeightRequest="36"
                                                Padding="0">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button"
                                                             Binding="{Binding IsLiked}"
                                                             Value="True">
                                                    <Setter Property="Text" Value="&#xe87d;"/>
                                                    <Setter Property="TextColor" Value="{StaticResource SpotifyGreen}"/>
                                                    <Setter Property="FontFamily" Value="MaterialIcons"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Button"
                                                             Binding="{Binding IsLiked}"
                                                             Value="False">
                                                    <Setter Property="Text" Value="&#xe87e;"/>
                                                    <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                                                    <Setter Property="FontFamily" Value="MaterialIcons"/>
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>

                                        <!-- Gradient overlay — bottom -->
                                        <Grid VerticalOptions="End" HeightRequest="85" InputTransparent="True">
                                            <Grid.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent" Offset="0.0"/>
                                                    <GradientStop Color="#EE282828" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Grid.Background>
                                        </Grid>

                                        <!-- Title / artist / duration over gradient -->
                                        <VerticalStackLayout VerticalOptions="End"
                                                             Padding="8,0,36,8" Spacing="2"
                                                             InputTransparent="True">
                                            <Label Text="{Binding Track.Title}"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                            <Label Text="{Binding Track.ArtistName}"
                                                   Style="{StaticResource CaptionLabel}"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                            <Label Text="{Binding Track.DurationMs, Converter={StaticResource DurationConverter}}"
                                                   FontSize="10"
                                                   TextColor="{StaticResource TextMuted}"/>
                                        </VerticalStackLayout>

                                        <!-- Add to playlist — bottom right -->
                                        <Button Text="&#xe03b;"
                                                FontFamily="MaterialIcons"
                                                FontSize="18"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource TextSecondary}"
                                                Command="{Binding Source={x:Reference TracksView}, Path=BindingContext.AddToPlaylistCommand}"
                                                CommandParameter="{Binding .}"
                                                HorizontalOptions="End"
                                                VerticalOptions="End"
                                                WidthRequest="32" HeightRequest="32"
                                                Padding="0"/>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- ── Альбоми ── -->
                    <HorizontalStackLayout Spacing="8" Margin="0,8,16,0" VerticalOptions="Center">
                        <BoxView WidthRequest="4" HeightRequest="22"
                                 Color="{StaticResource SpotifyGreen}"
                                 BackgroundColor="Transparent"
                                 VerticalOptions="Center"
                                 CornerRadius="2"/>
                        <Label Text="Альбоми"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="21"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <CollectionView x:Name="AlbumsView"
                                    ItemsSource="{Binding FeaturedAlbums}"
                                    HeightRequest="175">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <Label Text="Немає альбомів"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}"
                                        Padding="0"
                                        WidthRequest="145">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference AlbumsView}, Path=BindingContext.OpenAlbumCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid HeightRequest="165">

                                        <!-- Cover fills full card -->
                                        <Image Source="{Binding CoverUrl}"
                                               Aspect="AspectFill"/>

                                        <!-- Gradient overlay — bottom -->
                                        <Grid VerticalOptions="End" HeightRequest="70" InputTransparent="True">
                                            <Grid.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent" Offset="0.0"/>
                                                    <GradientStop Color="#EE282828" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Grid.Background>
                                        </Grid>

                                        <!-- Title / year over gradient -->
                                        <VerticalStackLayout VerticalOptions="End"
                                                             Padding="8,0,8,8" Spacing="2"
                                                             InputTransparent="True">
                                            <Label Text="{Binding Title}"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                            <Label Text="{Binding Year}"
                                                   Style="{StaticResource CaptionLabel}"/>
                                        </VerticalStackLayout>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- ── Артисти ── -->
                    <HorizontalStackLayout Spacing="8" Margin="0,8,16,0" VerticalOptions="Center">
                        <BoxView WidthRequest="4" HeightRequest="22"
                                 Color="{StaticResource SpotifyGreen}"
                                 BackgroundColor="Transparent"
                                 VerticalOptions="Center"
                                 CornerRadius="2"/>
                        <Label Text="Артисти"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="21"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <CollectionView x:Name="ArtistsView"
                                    ItemsSource="{Binding Artists}"
                                    HeightRequest="160">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="16"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <Label Text="Немає артистів"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout WidthRequest="125" Spacing="8">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference ArtistsView}, Path=BindingContext.OpenArtistCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </VerticalStackLayout.GestureRecognizers>
                                    <Border StrokeShape="Ellipse"
                                            StrokeThickness="0"
                                            Stroke="Transparent"
                                            BackgroundColor="{StaticResource BackgroundCard}"
                                            WidthRequest="115"
                                            HeightRequest="115"
                                            HorizontalOptions="Center">
                                        <Border.Shadow>
                                            <Shadow Brush="{StaticResource SpotifyGreen}"
                                                    Radius="12"
                                                    Opacity="0.25"
                                                    Offset="0,2"/>
                                        </Border.Shadow>
                                        <Image Source="{Binding CoverUrl}"
                                               Aspect="AspectFill"
                                               WidthRequest="115"
                                               HeightRequest="115"/>
                                    </Border>
                                    <Label Text="{Binding Name}"
                                           TextColor="{StaticResource TextPrimary}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           HorizontalTextAlignment="Center"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"
                                           Margin="4,0"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- MiniPlayer above TabBar -->
        <controls:MiniPlayer Grid.Row="1"/>
    </Grid>

</ContentPage>
