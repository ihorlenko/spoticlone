<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:SpotiClone.Views.Controls"
             x:Class="SpotiClone.Views.LibraryPage"
             Title="{Binding Title}"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Content area -->
        <Grid Grid.Row="0">

            <!-- Loading indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource SpotifyGreen}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

            <!-- Main content -->
            <ScrollView IsVisible="{Binding IsNotBusy}">
                <VerticalStackLayout Padding="16" Spacing="16">

                    <Label Text="Моя бібліотека"
                           Style="{StaticResource TitleLabel}"/>

                    <!-- Tab switcher -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">

                        <Button Grid.Column="0"
                                Text="Треки"
                                Command="{Binding SelectTracksTabCommand}"
                                CornerRadius="20"
                                HeightRequest="36"
                                FontSize="14">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding ShowTracks}"
                                             Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource SpotifyGreen}"/>
                                    <Setter Property="TextColor" Value="{StaticResource BackgroundDark}"/>
                                    <Setter Property="FontAttributes" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding ShowTracks}"
                                             Value="False">
                                    <Setter Property="BackgroundColor" Value="{StaticResource BackgroundElevated}"/>
                                    <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                                    <Setter Property="FontAttributes" Value="None"/>
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Button Grid.Column="1"
                                Text="Плейлисти"
                                Command="{Binding SelectPlaylistsTabCommand}"
                                CornerRadius="20"
                                HeightRequest="36"
                                FontSize="14">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding ShowPlaylists}"
                                             Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource SpotifyGreen}"/>
                                    <Setter Property="TextColor" Value="{StaticResource BackgroundDark}"/>
                                    <Setter Property="FontAttributes" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding ShowPlaylists}"
                                             Value="False">
                                    <Setter Property="BackgroundColor" Value="{StaticResource BackgroundElevated}"/>
                                    <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                                    <Setter Property="FontAttributes" Value="None"/>
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                    </Grid>

                    <!-- Liked Tracks tab -->
                    <VerticalStackLayout IsVisible="{Binding ShowTracks}" Spacing="0">

                        <!-- Empty state -->
                        <VerticalStackLayout IsVisible="{Binding HasNoLikedTracks}"
                                             Spacing="8"
                                             Margin="0,40,0,0"
                                             HorizontalOptions="Center">
                            <Label Text="♡"
                                   FontSize="48"
                                   TextColor="{StaticResource TextMuted}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Немає улюблених треків"
                                   Style="{StaticResource SubtitleLabel}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Натисніть ♥ на треку, щоб додати"
                                   Style="{StaticResource CaptionLabel}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Liked tracks list -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding LikedTracks}"
                                             Spacing="4">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorder}"
                                            Margin="0,0,0,4">
                                        <Grid ColumnDefinitions="56,*,44"
                                              ColumnSpacing="12"
                                              Padding="4">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PlayLikedTrackCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Grid.GestureRecognizers>

                                            <Border Grid.Column="0"
                                                    StrokeShape="RoundRectangle 6"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{StaticResource BackgroundElevated}"
                                                    WidthRequest="56"
                                                    HeightRequest="56">
                                                <Image Source="{Binding CoverUrl}"
                                                       Aspect="AspectFill"
                                                       WidthRequest="56"
                                                       HeightRequest="56"/>
                                            </Border>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="3"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Title}"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                                <Label Text="{Binding ArtistName}"
                                                       Style="{StaticResource CaptionLabel}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                            </VerticalStackLayout>

                                            <Button Grid.Column="2"
                                                    Text="♥"
                                                    TextColor="{StaticResource SpotifyGreen}"
                                                    BackgroundColor="Transparent"
                                                    FontSize="20"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.UnlikeTrackCommand}"
                                                    CommandParameter="{Binding .}"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    Padding="0"
                                                    VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Playlists tab -->
                    <VerticalStackLayout IsVisible="{Binding ShowPlaylists}" Spacing="12">

                        <Button Text="+ Створити плейлист"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding CreatePlaylistCommand}"
                                HorizontalOptions="Fill"
                                HeightRequest="44"/>

                        <!-- Empty state -->
                        <VerticalStackLayout IsVisible="{Binding HasNoPlaylists}"
                                             Spacing="8"
                                             Margin="0,32,0,0"
                                             HorizontalOptions="Center">
                            <Label Text="🎵"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label Text="Немає плейлистів"
                                   Style="{StaticResource SubtitleLabel}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Створіть перший плейлист"
                                   Style="{StaticResource CaptionLabel}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Playlists list -->
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Playlists}"
                                             Spacing="4">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CardBorder}"
                                            Margin="0,0,0,4">
                                        <Grid ColumnDefinitions="44,*,44"
                                              ColumnSpacing="12"
                                              Padding="4">

                                            <Label Grid.Column="0"
                                                   Text="🎵"
                                                   FontSize="28"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>

                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="3"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Name}"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                                <Label Text="{Binding CreatedAt, StringFormat='Створено: {0:dd.MM.yyyy}'}"
                                                       Style="{StaticResource CaptionLabel}"/>
                                            </VerticalStackLayout>

                                            <Button Grid.Column="2"
                                                    Text="✕"
                                                    TextColor="{StaticResource DangerColor}"
                                                    BackgroundColor="Transparent"
                                                    FontSize="16"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeletePlaylistCommand}"
                                                    CommandParameter="{Binding .}"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    Padding="0"
                                                    VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

        </Grid>

        <!-- MiniPlayer above TabBar -->
        <controls:MiniPlayer Grid.Row="1"/>
    </Grid>

</ContentPage>
