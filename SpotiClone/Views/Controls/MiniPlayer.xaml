<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SpotiClone.Views.Controls.MiniPlayer">

    <Grid HeightRequest="65"
          BackgroundColor="{StaticResource BackgroundCard}"
          IsVisible="{Binding HasCurrentTrack}">

        <Grid.RowDefinitions>
            <RowDefinition Height="57"/>
            <RowDefinition Height="8"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="44"/>
            <ColumnDefinition Width="44"/>
        </Grid.ColumnDefinitions>

        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding OpenPlayerCommand}"/>
        </Grid.GestureRecognizers>

        <!-- Cover image -->
        <Image Grid.Row="0" Grid.Column="0"
               Source="{Binding Player.CurrentTrack.CoverUrl}"
               Aspect="AspectFill"
               HeightRequest="57"
               WidthRequest="60"/>

        <!-- Track title + artist -->
        <VerticalStackLayout Grid.Row="0" Grid.Column="1"
                             VerticalOptions="Center"
                             Padding="8,0"
                             Spacing="2">
            <Label Text="{Binding Player.CurrentTrack.Title}"
                   TextColor="{StaticResource TextPrimary}"
                   FontSize="13"
                   FontAttributes="Bold"
                   LineBreakMode="TailTruncation"
                   MaxLines="1"/>
            <Label Text="{Binding Player.CurrentTrack.ArtistName}"
                   TextColor="{StaticResource TextSecondary}"
                   FontSize="11"
                   LineBreakMode="TailTruncation"
                   MaxLines="1"/>
        </VerticalStackLayout>

        <!-- Play/Pause button -->
        <Button Grid.Row="0" Grid.Column="2"
                FontFamily="MaterialIcons"
                Command="{Binding Player.PlayPauseCommand}"
                BackgroundColor="Transparent"
                TextColor="{StaticResource TextPrimary}"
                FontSize="22"
                HeightRequest="44"
                WidthRequest="44"
                Padding="0">
            <Button.Triggers>
                <DataTrigger TargetType="Button"
                             Binding="{Binding Player.IsPlaying}"
                             Value="True">
                    <Setter Property="Text" Value="&#xe034;"/>
                </DataTrigger>
                <DataTrigger TargetType="Button"
                             Binding="{Binding Player.IsPlaying}"
                             Value="False">
                    <Setter Property="Text" Value="&#xe037;"/>
                </DataTrigger>
            </Button.Triggers>
        </Button>

        <!-- Next track button -->
        <Button Grid.Row="0" Grid.Column="3"
                Text="&#xe044;"
                FontFamily="MaterialIcons"
                Command="{Binding Player.NextCommand}"
                BackgroundColor="Transparent"
                TextColor="{StaticResource TextPrimary}"
                FontSize="18"
                HeightRequest="44"
                WidthRequest="44"
                Padding="0"/>

        <!-- Progress bar — gestures on Grid (transparent BoxView doesn't receive touches on iOS) -->
        <Grid x:Name="SeekBarContainer"
              Grid.Row="1" Grid.ColumnSpan="4">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSeekBarTapped"/>
                <PanGestureRecognizer PanUpdated="OnSeekBarPanned"/>
            </Grid.GestureRecognizers>
            <BoxView BackgroundColor="{StaticResource TextMuted}"
                     HeightRequest="3" VerticalOptions="End"
                     InputTransparent="True"/>
            <BoxView x:Name="SeekBarFill"
                     BackgroundColor="{StaticResource SpotifyGreen}"
                     HorizontalOptions="Start"
                     VerticalOptions="End"
                     HeightRequest="3"
                     WidthRequest="0"
                     InputTransparent="True"/>
        </Grid>
    </Grid>

</ContentView>
